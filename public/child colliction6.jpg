 للمساعدة على إنهاء النفايات البلاستيكية.","offers":{"@type":"Offer","priceCurrency":"EGP","price":5599.3,"availability":"InStock","url":"https://www.adidas.com.eg/ar/%D8%AD%D8%B0%D8%A7%D8%A1-everyset-training/HP3263.html"},"isVariantOf":{"@type":"ProductGroup","name":"حذاء Everyset Training","productGroupID":"LYP63","hasVariant":[{"@type":"Product","sku":"HP3263","color":"Grey Two / Cloud White / Cloud White","url":"https://www.adidas.com.eg/ar/%D8%AD%D8%B0%D8%A7%D8%A1-everyset-training/HP3263.html"},{"@type":"Product","sku":"ID4989","color":"Core Black / Cloud White / Cloud White","url":"https://www.adidas.com.eg/ar/%D8%AD%D8%B0%D8%A7%D8%A1-everyset-training/ID4989.html"},{"@type":"Product","sku":"ID4990","color":"Cloud White / Core Black / Grey One","url":"https://www.adidas.com.eg/ar/%D8%AD%D8%B0%D8%A7%D8%A1-everyset-training/ID4990.html"}]}}
